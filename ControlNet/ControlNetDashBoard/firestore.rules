// Firestore Security Rules for ControlNet Dashboard
// Copy these rules to Firebase Console → Firestore Database → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Devices subcollection - users can only access their own devices
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Sequences subcollection - users can only access sequences for their devices
        match /sequences/{sequenceId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
    
    // Alternative flatter structure (if you prefer)
    // Devices collection with userId field
    match /devices/{deviceId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }
    
    // Sequences collection with userId field
    match /sequences/{sequenceId} {
      allow read, write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
    }
  }
}